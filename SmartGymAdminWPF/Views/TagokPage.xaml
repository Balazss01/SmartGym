<Page x:Class="SmartGymAdminWPF.Views.TagokPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0B1120">

    <Page.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1F2937"/>
            <Setter Property="VerticalGridLinesBrush" Value="#1F2937"/>
            <Setter Property="RowBackground" Value="#0F172A"/>
            <Setter Property="AlternatingRowBackground" Value="#111827"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#1F2937"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#1F2937"/>
        </Style>

        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,16">
            <TextBlock Text="Tagok"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       DockPanel.Dock="Left"/>

            <TextBox x:Name="SearchBox"
                     Width="260"
                     Height="38"
                     Padding="10"
                     Background="#111827"
                     Foreground="White"
                     BorderBrush="#1F2937"
                     TextChanged="Search"
                     HorizontalAlignment="Right"/>
        </DockPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <Button Content="Frissítés"
                    Style="{StaticResource TopButtonStyle}"
                    Click="Refresh_Click"/>

            <Button Content="Kijelölt sor törlése"
                    Style="{StaticResource TopButtonStyle}"
                    Background="#DC2626"
                    Click="Delete_Click"/>
        </StackPanel>

        <Border Grid.Row="2"
                Background="#111827"
                CornerRadius="18"
                Padding="14">
            <DataGrid x:Name="UsersGrid"
                      AutoGenerateColumns="True"/>
        </Border>
    </Grid>
</Page>