<Page x:Class="SmartGymAdminWPF.Views.TagokPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FEJLÉC -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="TAGKEZELÉS"
                       Foreground="#00f5c4" FontSize="11" FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Tagok"
                       FontSize="26" FontWeight="Bold"
                       Foreground="#f0ede8"/>
        </StackPanel>

        <!-- STAT KÁRTYÁK -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="-6,0">
            <Border Margin="6" Padding="22,18" CornerRadius="18"
                    Background="#0f0f1a" BorderBrush="#1f1f2e" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="ÖSSZES TAG" Foreground="#3a3a4a" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock x:Name="OsszesTagText" Text="0"
                               Foreground="#f0ede8" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Margin="6" Padding="22,18" CornerRadius="18"
                    Background="#0f0f1a" BorderBrush="#1f1f2e" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="AKTÍV TAG" Foreground="#3a3a4a" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock x:Name="AktivTagText" Text="0"
                               Foreground="#00f5c4" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Margin="6" Padding="22,18" CornerRadius="18"
                    Background="#0f0f1a" BorderBrush="#1f1f2e" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="INAKTÍV TAG" Foreground="#3a3a4a" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock x:Name="InaktivTagText" Text="0"
                               Foreground="#f87171" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- SZŰRŐK -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="KeresesTextBox"
                     Style="{StaticResource ModernTextBoxStyle}"
                     TextChanged="KeresesTextBox_TextChanged"/>

            <CheckBox x:Name="CsakAktivCheckBox"
                      Grid.Column="2"
                      Foreground="#6b6760"
                      FontSize="13"
                      Content="Csak aktív"
                      VerticalAlignment="Center"
                      Checked="CsakAktivCheckBox_Changed"
                      Unchecked="CsakAktivCheckBox_Changed"/>

            <Button Grid.Column="4"
                    Content="Frissítés"
                    Width="120" Height="42"
                    Style="{StaticResource ModernButtonStyle}"
                    Click="FrissitesButton_Click"/>
        </Grid>

        <!-- TÁBLÁZAT -->
        <Border Grid.Row="6" Background="#0f0f1a" CornerRadius="18"
                BorderBrush="#1f1f2e" BorderThickness="1">
            <DataGrid x:Name="TagokGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserAddRows="False"
                      Background="#0f0f1a"
                      Foreground="#f0ede8"
                      RowBackground="#0f0f1a"
                      AlternatingRowBackground="#0c0c15"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#1a1a28"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      RowHeight="46"
                      FontSize="13">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#09090f"/>
                        <Setter Property="Foreground" Value="#4a4740"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="BorderBrush" Value="#1f1f2e"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="Height" Value="40"/>
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0d2520"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#131320"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#00f5c4"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"             Binding="{Binding TagId}"          IsReadOnly="True" Width="*"/>
                    <DataGridTextColumn Header="NÉV"            Binding="{Binding TeljesNev}"       IsReadOnly="True" Width="2*"/>
                    <DataGridTextColumn Header="VEZETÉKNÉV"     Binding="{Binding Vezeteknev}"      IsReadOnly="True" Width="2*"/>
                    <DataGridTextColumn Header="KERESZTNÉV"     Binding="{Binding Keresztnev}"      IsReadOnly="True" Width="2*"/>
                    <DataGridTextColumn Header="SZÜLETÉSI DÁTUM"
                                        Binding="{Binding SzuletesiDatum, StringFormat=yyyy.MM.dd}"
                                        IsReadOnly="True" Width="2*"/>
                    <DataGridTemplateColumn Header="AKTÍV" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Aktiv}"
                                          HorizontalAlignment="Center"
                                          Checked="AktivChanged"
                                          Unchecked="AktivChanged"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
