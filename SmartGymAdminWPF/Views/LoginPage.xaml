<Page x:Class="SmartGymAdminWPF.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LoginPage"
      Background="{StaticResource BgBrush}">

    <Grid>
        <Border Width="460"
                Padding="35"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrushCustom}"
                BorderThickness="1"
                CornerRadius="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="SmartGym Admin"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Bejelentkezés az admin felületre"
                           Margin="0,8,0,24"
                           Foreground="{StaticResource SubTextBrush}"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Email"
                           Foreground="White"
                           Margin="0,0,0,6"/>

                <TextBox x:Name="EmailTextBox"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="Jelszó"
                           Foreground="White"
                           Margin="0,0,0,6"/>

                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource ModernPasswordBoxStyle}"
                             Margin="0,0,0,22"/>

                <Button Content="Bejelentkezés"
                        Height="42"
                        Style="{StaticResource ModernButtonStyle}"
                        Click="LoginButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>