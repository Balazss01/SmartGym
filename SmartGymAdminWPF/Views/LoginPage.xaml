<Page x:Class="SmartGymAdminWPF.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LoginPage"
      Background="#1e293b">

    <Grid>
        <Border Width="420"
                Padding="30"
                Background="#0f172a"
                CornerRadius="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Admin bejelentkezés"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Email"
                           Foreground="White"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="EmailTextBox"
                         Height="35"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Jelszó"
                           Foreground="White"
                           Margin="0,0,0,5"/>

                <PasswordBox x:Name="PasswordBox"
                             Height="35"
                             Margin="0,0,0,20"/>

                <Button Content="Bejelentkezés"
                        Height="40"
                        Click="LoginButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>