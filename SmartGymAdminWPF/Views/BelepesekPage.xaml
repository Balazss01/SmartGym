<Page x:Class="SmartGymAdminWPF.Views.BelepesekPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0B1120">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Belépések"
                   Foreground="White"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <Border Grid.Row="1" Background="#111827" CornerRadius="18" Padding="14">
            <DataGrid x:Name="Grid"
                      AutoGenerateColumns="True"
                      Background="Transparent"
                      Foreground="White"
                      BorderThickness="0"/>
        </Border>
    </Grid>
</Page>