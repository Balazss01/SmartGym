<Page x:Class="SmartGymAdminWPF.Views.BerletekPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Bérletek"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"/>

        <UniformGrid Grid.Row="2" Columns="3">
            <Border Background="{StaticResource CardBrush}" CornerRadius="12" Margin="6" Padding="16">
                <StackPanel>
                    <TextBlock Text="Összes bérlet" Foreground="{StaticResource SubTextBrush}" FontSize="14"/>
                    <TextBlock x:Name="OsszesBerletText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardBrush}" CornerRadius="12" Margin="6" Padding="16">
                <StackPanel>
                    <TextBlock Text="Aktív bérlet" Foreground="{StaticResource SubTextBrush}" FontSize="14"/>
                    <TextBlock x:Name="AktivBerletText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardBrush}" CornerRadius="12" Margin="6" Padding="16">
                <StackPanel>
                    <TextBlock Text="Lejárt bérlet" Foreground="{StaticResource SubTextBrush}" FontSize="14"/>
                    <TextBlock x:Name="LejartBerletText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="KeresesTextBox"
                     Style="{StaticResource ModernTextBoxStyle}"
                     TextChanged="KeresesTextBox_TextChanged"/>

            <CheckBox x:Name="CsakAktivCheckBox"
                      Grid.Column="2"
                      VerticalAlignment="Center"
                      Foreground="White"
                      FontSize="14"
                      Content="Csak aktív"
                      Checked="FilterChanged"
                      Unchecked="FilterChanged"/>

            <CheckBox x:Name="CsakLejartCheckBox"
                      Grid.Column="4"
                      VerticalAlignment="Center"
                      Foreground="White"
                      FontSize="14"
                      Content="Csak lejárt"
                      Checked="FilterChanged"
                      Unchecked="FilterChanged"/>

            <ComboBox x:Name="BerletTipusComboBox"
                      Grid.Column="6"
                      Height="38"                
                      SelectionChanged="FilterChanged">
                <ComboBoxItem Content="Összes típus"/>
            </ComboBox>

            <Button Grid.Column="8"
                    Content="Frissítés"
                    Width="120"
                    Height="38"
                    Style="{StaticResource ModernButtonStyle}"
                    Click="FrissitesButton_Click"/>
        </Grid>

        <DataGrid x:Name="BerletekGrid"
                  Grid.Row="6"
                  Style="{StaticResource ModernDataGridStyle}"
                  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding BerletId}" Width="*"/>
                <DataGridTextColumn Header="Tag ID" Binding="{Binding TagId}" Width="*"/>
                <DataGridTextColumn Header="Név" Binding="{Binding TeljesNev}" Width="2*"/>
                <DataGridTextColumn Header="Bérlet típusa" Binding="{Binding BerletTipusNev}" Width="2*"/>
                <DataGridTextColumn Header="Kezdet" Binding="{Binding KezdetDatum, StringFormat=yyyy.MM.dd HH:mm}" Width="2*"/>
                <DataGridTextColumn Header="Indulás" Binding="{Binding KezdetDatum, StringFormat=yyyy.MM.dd}" Width="2*"/>
                <DataGridTextColumn Header="Vége" Binding="{Binding VegeDatum, StringFormat=yyyy.MM.dd HH:mm}" Width="2*"/>

                <DataGridTemplateColumn Header="Státusz" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="6"
                    CornerRadius="8"
                    HorizontalAlignment="Center">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#dc2626"/>
                                        <!-- LEJÁRT -->

                                        <Style.Triggers>

                                            <!-- AKTÍV -->
                                            <DataTrigger Binding="{Binding Statusz}" Value="AKTÍV">
                                                <Setter Property="Background" Value="#16a34a"/>
                                            </DataTrigger>

                                            <!-- ELŐRE MEGVÁSÁROLT -->
                                            <DataTrigger Binding="{Binding Statusz}" Value="ELŐRE MEGVÁSÁROLT">
                                                <Setter Property="Background" Value="#2563eb"/>
                                            </DataTrigger>

                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <TextBlock Text="{Binding Statusz}"
                           Foreground="White"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Művelet" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Állapot váltás"
                                    Padding="8,4"
                                    Click="ToggleBerlet_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>