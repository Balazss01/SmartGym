<Page x:Class="SmartGymAdminWPF.Views.BerletekPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="BerletekPage"
      Background="#1e293b">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Bérletek"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"/>

        <DataGrid x:Name="BerletekGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Background="#0f172a"
                  Foreground="White"
                  RowBackground="#1e293b"
                  AlternatingRowBackground="#111827"
                  BorderBrush="#334155"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding BerletId}" Width="*"/>
                <DataGridTextColumn Header="Tag ID" Binding="{Binding TagId}" Width="*"/>
                <DataGridTextColumn Header="Név" Binding="{Binding TeljesNev}" Width="2*"/>
                <DataGridTextColumn Header="Bérlet típusa" Binding="{Binding BerletTipusNev}" Width="2*"/>
                <DataGridTextColumn Header="Kezdet" Binding="{Binding KezdetDatum}" Width="2*"/>
                <DataGridTextColumn Header="Vége" Binding="{Binding VegeDatum}" Width="2*"/>
                <DataGridCheckBoxColumn Header="Aktív" Binding="{Binding Aktiv}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>