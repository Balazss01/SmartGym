<Page x:Class="SmartGymAdminWPF.Views.BerletekPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FEJLÉC -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="BÉRLETKEZELÉS"
                       Foreground="#00f5c4" FontSize="11" FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Bérletek"
                       FontSize="26" FontWeight="Bold"
                       Foreground="#f0ede8"/>
        </StackPanel>

        <!-- STAT KÁRTYÁK -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="-6,0">
            <Border Margin="6" Padding="22,18" CornerRadius="18"
                    Background="#0f0f1a" BorderBrush="#1f1f2e" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="ÖSSZES BÉRLET" Foreground="#3a3a4a" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock x:Name="OsszesBerletText" Text="0"
                               Foreground="#f0ede8" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Margin="6" Padding="22,18" CornerRadius="18"
                    Background="#0f0f1a" BorderBrush="#1f1f2e" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="AKTÍV BÉRLET" Foreground="#3a3a4a" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock x:Name="AktivBerletText" Text="0"
                               Foreground="#00f5c4" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Margin="6" Padding="22,18" CornerRadius="18"
                    Background="#0f0f1a" BorderBrush="#1f1f2e" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="LEJÁRT BÉRLET" Foreground="#3a3a4a" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock x:Name="LejartBerletText" Text="0"
                               Foreground="#f87171" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- SZŰRŐK -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="KeresesTextBox"
                     Style="{StaticResource ModernTextBoxStyle}"
                     TextChanged="KeresesTextBox_TextChanged"/>

            <CheckBox x:Name="CsakAktivCheckBox"
                      Grid.Column="2" VerticalAlignment="Center"
                      Foreground="#6b6760" FontSize="13" Content="Csak aktív"
                      Checked="FilterChanged" Unchecked="FilterChanged"/>

            <CheckBox x:Name="CsakLejartCheckBox"
                      Grid.Column="4" VerticalAlignment="Center"
                      Foreground="#6b6760" FontSize="13" Content="Csak lejárt"
                      Checked="FilterChanged" Unchecked="FilterChanged"/>

            <ComboBox x:Name="BerletTipusComboBox"
                      Grid.Column="6"
                      Height="42"
                      Background="#0f0f1a"
                      Foreground="#f0ede8"
                      BorderBrush="#1f1f2e"
                      BorderThickness="1"
                      FontSize="13"
                      SelectionChanged="FilterChanged">
                <ComboBoxItem Content="Összes típus"/>
            </ComboBox>

            <Button Grid.Column="8"
                    Content="Frissítés"
                    Width="120" Height="42"
                    Style="{StaticResource ModernButtonStyle}"
                    Click="FrissitesButton_Click"/>
        </Grid>

        <!-- TÁBLÁZAT -->
        <Border Grid.Row="6" Background="#0f0f1a" CornerRadius="18"
                BorderBrush="#1f1f2e" BorderThickness="1">
            <DataGrid x:Name="BerletekGrid"
                      Style="{StaticResource ModernDataGridStyle}"
                      AutoGenerateColumns="False"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"          Binding="{Binding BerletId}"      Width="*"/>
                    <DataGridTextColumn Header="TAG ID"      Binding="{Binding TagId}"         Width="*"/>
                    <DataGridTextColumn Header="NÉV"         Binding="{Binding TeljesNev}"     Width="2*"/>
                    <DataGridTextColumn Header="BÉRLET TÍPUS" Binding="{Binding BerletTipusNev}" Width="2*"/>
                    <DataGridTextColumn Header="KEZDET"
                                        Binding="{Binding KezdetDatum, StringFormat=yyyy.MM.dd}" Width="2*"/>
                    <DataGridTextColumn Header="VÉGE"
                                        Binding="{Binding VegeDatum, StringFormat=yyyy.MM.dd}" Width="2*"/>

                    <!-- STÁTUSZ BADGE  (frontend: pill badge stílus) -->
                    <DataGridTemplateColumn Header="STÁTUSZ" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="10,4" CornerRadius="20"
                                        HorizontalAlignment="Left" Margin="4,0"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <!-- default: lejárt -->
                                            <Setter Property="Background" Value="#1a0a0a"/>
                                            <Setter Property="BorderBrush" Value="#3a1515"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Statusz}" Value="AKTÍV">
                                                    <Setter Property="Background" Value="#0d1f14"/>
                                                    <Setter Property="BorderBrush" Value="#1a4a28"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Statusz}" Value="ELŐRE MEGVÁSÁROLT">
                                                    <Setter Property="Background" Value="#13101f"/>
                                                    <Setter Property="BorderBrush" Value="#2a1f4a"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Statusz}"
                                               FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#f87171"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Statusz}" Value="AKTÍV">
                                                        <Setter Property="Foreground" Value="#00f5c4"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Statusz}" Value="ELŐRE MEGVÁSÁROLT">
                                                        <Setter Property="Foreground" Value="#7c6af8"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- MŰVELET GOMB -->
                    <DataGridTemplateColumn Header="MŰVELET" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Váltás"
                                        Padding="10,4"
                                        Height="30"
                                        Margin="4,0"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="#09090f"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="ToggleBerlet_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#00f5c4" Offset="0"/>
                                                        <GradientStop Color="#7c6af8" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
