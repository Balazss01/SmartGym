<Page x:Class="SmartGymAdminWPF.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DashboardPage"
      Background="#1e293b">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Admin Dashboard"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="White"/>

            <UniformGrid Grid.Row="2" Columns="4">
                <Border Background="#0f172a" CornerRadius="12" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Összes tag" Foreground="#94a3b8" FontSize="14"/>
                        <TextBlock x:Name="OsszesTagText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="#0f172a" CornerRadius="12" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Aktív tag" Foreground="#94a3b8" FontSize="14"/>
                        <TextBlock x:Name="AktivTagText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="#0f172a" CornerRadius="12" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Összes bérlet" Foreground="#94a3b8" FontSize="14"/>
                        <TextBlock x:Name="OsszesBerletText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="#0f172a" CornerRadius="12" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Aktív bérlet" Foreground="#94a3b8" FontSize="14"/>
                        <TextBlock x:Name="AktivBerletText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="#0f172a" CornerRadius="12" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Mai belépések" Foreground="#94a3b8" FontSize="14"/>
                        <TextBlock x:Name="MaiBelepesText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="#0f172a" CornerRadius="12" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Jelenleg bent" Foreground="#94a3b8" FontSize="14"/>
                        <TextBlock x:Name="BentLevokText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="#0f172a" CornerRadius="12" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Aktív foglalások" Foreground="#94a3b8" FontSize="14"/>
                        <TextBlock x:Name="SzekrenyFoglalasText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="4"
                    Background="#0f172a"
                    CornerRadius="12"
                    Padding="16"
                    Margin="6">
                <StackPanel>
                    <TextBlock Text="Utolsó 10 belépés"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <DataGrid x:Name="UtolsoBelepesekGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Background="#111827"
                              Foreground="White"
                              RowBackground="#1e293b"
                              AlternatingRowBackground="#0f172a"
                              BorderBrush="#334155"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding BelepesId}" Width="*"/>
                            <DataGridTextColumn Header="Név" Binding="{Binding TeljesNev}" Width="2*"/>
                            <DataGridTextColumn Header="Belépés" Binding="{Binding BelepesIdopont}" Width="2*"/>
                            <DataGridTextColumn Header="Kilépés" Binding="{Binding KilepesIdopont}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>