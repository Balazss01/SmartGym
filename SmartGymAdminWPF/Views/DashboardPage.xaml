<Page x:Class="SmartGymAdminWPF.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0B1120">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#111827" CornerRadius="18" Padding="20" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Összes tag" Foreground="#94A3B8" FontSize="13"/>
                    <TextBlock x:Name="TagCountText" Text="0" Foreground="White" FontSize="30" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#111827" CornerRadius="18" Padding="20" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Belépések" Foreground="#94A3B8" FontSize="13"/>
                    <TextBlock x:Name="BelepesCountText" Text="0" Foreground="White" FontSize="30" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#111827" CornerRadius="18" Padding="20">
                <StackPanel>
                    <TextBlock Text="Bérletek" Foreground="#94A3B8" FontSize="13"/>
                    <TextBlock x:Name="BerletCountText" Text="0" Foreground="White" FontSize="30" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Background="#111827"
                CornerRadius="18"
                Padding="20"
                Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Statisztika"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"/>
                <TextBlock Text="Chart placeholder"
                           Foreground="#94A3B8"
                           FontSize="13"
                           Margin="0,6,0,14"/>

                <UniformGrid Columns="7" Height="180">
                    <Border Background="#2563EB" CornerRadius="12" Margin="6" VerticalAlignment="Bottom" Height="80"/>
                    <Border Background="#2563EB" CornerRadius="12" Margin="6" VerticalAlignment="Bottom" Height="120"/>
                    <Border Background="#2563EB" CornerRadius="12" Margin="6" VerticalAlignment="Bottom" Height="65"/>
                    <Border Background="#2563EB" CornerRadius="12" Margin="6" VerticalAlignment="Bottom" Height="140"/>
                    <Border Background="#2563EB" CornerRadius="12" Margin="6" VerticalAlignment="Bottom" Height="90"/>
                    <Border Background="#2563EB" CornerRadius="12" Margin="6" VerticalAlignment="Bottom" Height="160"/>
                    <Border Background="#2563EB" CornerRadius="12" Margin="6" VerticalAlignment="Bottom" Height="110"/>
                </UniformGrid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#111827" CornerRadius="18" Padding="20">
            <StackPanel>
                <TextBlock Text="Rendszer állapot"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"/>
                <TextBlock x:Name="StatsText"
                           Foreground="#CBD5E1"
                           FontSize="14"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>