<Page x:Class="SmartGymAdminWPF.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Admin Dashboard"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="FrissitveText"
                               Text="Utolsó frissítés: -"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource SubTextBrush}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Frissítés"
                        Width="120"
                        Height="38"
                        Style="{StaticResource ModernButtonStyle}"
                        Click="FrissitesButton_Click"/>

                <CheckBox x:Name="AutoRefreshCheckBox"
                          Grid.Column="3"
                          VerticalAlignment="Center"
                          Foreground="White"
                          FontSize="14"
                          Content="Auto refresh"
                          Checked="AutoRefreshCheckBox_Checked"
                          Unchecked="AutoRefreshCheckBox_Unchecked"/>
            </Grid>

            <UniformGrid Grid.Row="2" Columns="4">
                <Border Background="{StaticResource CardBrush}" CornerRadius="14" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Összes tag" Foreground="{StaticResource SubTextBrush}" FontSize="14"/>
                        <TextBlock x:Name="OsszesTagText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBrush}" CornerRadius="14" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Aktív tag" Foreground="{StaticResource SubTextBrush}" FontSize="14"/>
                        <TextBlock x:Name="AktivTagText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBrush}" CornerRadius="14" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Összes bérlet" Foreground="{StaticResource SubTextBrush}" FontSize="14"/>
                        <TextBlock x:Name="OsszesBerletText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBrush}" CornerRadius="14" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Aktív bérlet" Foreground="{StaticResource SubTextBrush}" FontSize="14"/>
                        <TextBlock x:Name="AktivBerletText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBrush}" CornerRadius="14" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Mai belépések" Foreground="{StaticResource SubTextBrush}" FontSize="14"/>
                        <TextBlock x:Name="MaiBelepesText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBrush}" CornerRadius="14" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Jelenleg bent" Foreground="{StaticResource SubTextBrush}" FontSize="14"/>
                        <TextBlock x:Name="BentLevokText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBrush}" CornerRadius="14" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Aktív foglalások" Foreground="{StaticResource SubTextBrush}" FontSize="14"/>
                        <TextBlock x:Name="SzekrenyFoglalasText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource CardBrush}"
                        CornerRadius="14"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Heti belépések"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>

                        <ItemsControl x:Name="HetiBelepesekItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Datum}"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>

                                        <ProgressBar Grid.Column="1"
                                                     Height="20"
                                                     Margin="10,0"
                                                     Minimum="0"
                                                     Maximum="{Binding MaxErtek}"
                                                     Value="{Binding Darab}"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Darab}"
                                                   Foreground="White"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="{StaticResource CardBrush}"
                        CornerRadius="14"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Bérlet megoszlás"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Aktív"
                                   Foreground="{StaticResource SubTextBrush}"/>
                        <ProgressBar x:Name="AktivBerletProgress"
                                     Height="24"
                                     Margin="0,6,0,4"
                                     Minimum="0"/>
                        <TextBlock x:Name="AktivBerletAranyText"
                                   Foreground="White"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Lejárt / inaktív"
                                   Foreground="{StaticResource SubTextBrush}"/>
                        <ProgressBar x:Name="LejartBerletProgress"
                                     Height="24"
                                     Margin="0,6,0,4"
                                     Minimum="0"/>
                        <TextBlock x:Name="LejartBerletAranyText"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="6"
                    Background="{StaticResource CardBrush}"
                    CornerRadius="14"
                    Padding="16"
                    Margin="6">
                <StackPanel>
                    <TextBlock Text="Jelenleg bent lévők"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <DataGrid x:Name="BentLevokGrid"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False"
                              Height="220">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Belépés ID" Binding="{Binding BelepesId}" Width="*"/>
                            <DataGridTextColumn Header="Tag ID" Binding="{Binding TagId}" Width="*"/>
                            <DataGridTextColumn Header="Név" Binding="{Binding TeljesNev}" Width="2*"/>
                            <DataGridTextColumn Header="Belépett" Binding="{Binding BelepesIdopont, StringFormat=yyyy.MM.dd HH:mm}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Grid.Row="8"
                    Background="{StaticResource CardBrush}"
                    CornerRadius="14"
                    Padding="16"
                    Margin="6">
                <StackPanel>
                    <TextBlock Text="Utolsó 10 belépés"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <DataGrid x:Name="UtolsoBelepesekGrid"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding BelepesId}" Width="*"/>
                            <DataGridTextColumn Header="Név" Binding="{Binding TeljesNev}" Width="2*"/>
                            <DataGridTextColumn Header="Belépés" Binding="{Binding BelepesIdopont, StringFormat=yyyy.MM.dd HH:mm}" Width="2*"/>
                            <DataGridTextColumn Header="Kilépés" Binding="{Binding KilepesIdopont, StringFormat=yyyy.MM.dd HH:mm}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>