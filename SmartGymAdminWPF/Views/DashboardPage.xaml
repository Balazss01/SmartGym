<Page x:Class="SmartGymAdminWPF.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── FEJLÉC ── -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <!-- page-tag -->
                    <TextBlock Text="ADMIN PANEL"
                               Foreground="#00f5c4"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <!-- page-title -->
                    <TextBlock Text="Dashboard"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#f0ede8"/>
                    <TextBlock x:Name="FrissitveText"
                               Text="Utolsó frissítés: —"
                               Foreground="#3a3a4a"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Frissítés"
                        Width="120" Height="38"
                        Style="{StaticResource ModernButtonStyle}"
                        Click="FrissitesButton_Click"/>

                <CheckBox x:Name="AutoRefreshCheckBox"
                          Grid.Column="3"
                          VerticalAlignment="Center"
                          Foreground="#4a4740"
                          FontSize="13"
                          Content="Auto refresh"
                          Checked="AutoRefreshCheckBox_Checked"
                          Unchecked="AutoRefreshCheckBox_Unchecked"/>
            </Grid>

            <!-- ── STAT KÁRTYÁK  (frontend: .berlet-card stílus) ── -->
            <UniformGrid Grid.Row="2" Columns="4" Margin="-6,0">

                <!-- Összes tag -->
                <Border Margin="6" Padding="22,18" CornerRadius="18"
                        BorderBrush="#1f1f2e" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0f0f1a"/>
                    </Border.Background>
                    <StackPanel>
                        <Border Width="36" Height="36" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Border.Background>
                                <SolidColorBrush Color="#0d1f1c"/>
                            </Border.Background>
                            <TextBlock Text="👥" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Összes tag" Foreground="#3a3a4a" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock x:Name="OsszesTagText" Text="0"
                                   Foreground="#f0ede8" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Aktív tag -->
                <Border Margin="6" Padding="22,18" CornerRadius="18"
                        BorderBrush="#1f1f2e" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0f0f1a"/>
                    </Border.Background>
                    <StackPanel>
                        <Border Width="36" Height="36" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,12"
                                Background="#0d1f14">
                            <TextBlock Text="✓" FontSize="16" Foreground="#00f5c4"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Aktív tag" Foreground="#3a3a4a" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock x:Name="AktivTagText" Text="0"
                                   Foreground="#00f5c4" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Összes bérlet -->
                <Border Margin="6" Padding="22,18" CornerRadius="18"
                        BorderBrush="#1f1f2e" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0f0f1a"/>
                    </Border.Background>
                    <StackPanel>
                        <Border Width="36" Height="36" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,12"
                                Background="#13101f">
                            <TextBlock Text="🎫" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Összes bérlet" Foreground="#3a3a4a" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock x:Name="OsszesBerletText" Text="0"
                                   Foreground="#f0ede8" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Aktív bérlet -->
                <Border Margin="6" Padding="22,18" CornerRadius="18"
                        BorderBrush="#1f1f2e" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0f0f1a"/>
                    </Border.Background>
                    <StackPanel>
                        <Border Width="36" Height="36" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,12"
                                Background="#13101f">
                            <TextBlock Text="★" FontSize="16" Foreground="#7c6af8"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Aktív bérlet" Foreground="#3a3a4a" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock x:Name="AktivBerletText" Text="0"
                                   Foreground="#7c6af8" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Előre megvásárolt -->
                <Border Margin="6" Padding="22,18" CornerRadius="18"
                        BorderBrush="#1f1f2e" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0f0f1a"/>
                    </Border.Background>
                    <StackPanel>
                        <Border Width="36" Height="36" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,12"
                                Background="#13101f">
                            <TextBlock Text="⏭" FontSize="14" Foreground="#a78bfa"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Előre megvásárolt" Foreground="#3a3a4a" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock x:Name="EloreMegvasaroltBerletText" Text="0"
                                   Foreground="#a78bfa" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Mai belépések -->
                <Border Margin="6" Padding="22,18" CornerRadius="18"
                        BorderBrush="#1f1f2e" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0f0f1a"/>
                    </Border.Background>
                    <StackPanel>
                        <Border Width="36" Height="36" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,12"
                                Background="#0d1f14">
                            <TextBlock Text="↪" FontSize="16" Foreground="#4ade80"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Mai belépések" Foreground="#3a3a4a" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock x:Name="MaiBelepesText" Text="0"
                                   Foreground="#4ade80" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Jelenleg bent -->
                <Border Margin="6" Padding="22,18" CornerRadius="18"
                        BorderBrush="#1f1f2e" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0f0f1a"/>
                    </Border.Background>
                    <StackPanel>
                        <Border Width="36" Height="36" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,12"
                                Background="#1f1508">
                            <TextBlock Text="◉" FontSize="14" Foreground="#fbbf24"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Jelenleg bent" Foreground="#3a3a4a" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock x:Name="BentLevokText" Text="0"
                                   Foreground="#fbbf24" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Aktív foglalások -->
                <Border Margin="6" Padding="22,18" CornerRadius="18"
                        BorderBrush="#1f1f2e" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#0f0f1a"/>
                    </Border.Background>
                    <StackPanel>
                        <Border Width="36" Height="36" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,12"
                                Background="#13101f">
                            <TextBlock Text="⊞" FontSize="14" Foreground="#7c6af8"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Aktív foglalások" Foreground="#3a3a4a" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock x:Name="SzekrenyFoglalasText" Text="0"
                                   Foreground="#7c6af8" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── GRAFIKON SOR ── -->
            <Grid Grid.Row="4" Margin="-6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Heti belépések -->
                <Border Background="#0f0f1a" CornerRadius="18" Padding="22"
                        BorderBrush="#1f1f2e" BorderThickness="1" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="HETI BELÉPÉSEK"
                                   Foreground="#00f5c4" FontSize="10" FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Belépések az elmúlt 7 napban"
                                   Foreground="#f0ede8" FontSize="16" FontWeight="Bold"
                                   Margin="0,0,0,18"/>
                        <ItemsControl x:Name="HetiBelepesekItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Datum}"
                                                   Foreground="#4a4740" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" Height="6"
                                                     Margin="10,0" Minimum="0"
                                                     Maximum="{Binding MaxErtek}"
                                                     Value="{Binding Darab}"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Darab}"
                                                   Foreground="#f0ede8" FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Bérlet megoszlás -->
                <Border Grid.Column="2" Background="#0f0f1a" CornerRadius="18" Padding="22"
                        BorderBrush="#1f1f2e" BorderThickness="1" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="BÉRLET MEGOSZLÁS"
                                   Foreground="#00f5c4" FontSize="10" FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Státusz szerinti bontás"
                                   Foreground="#f0ede8" FontSize="16" FontWeight="Bold"
                                   Margin="0,0,0,22"/>

                        <TextBlock Text="AKTÍV" Foreground="#3a3a4a" FontSize="10" FontWeight="SemiBold"/>
                        <ProgressBar x:Name="AktivBerletProgress"
                                     Height="6" Margin="0,6,0,4" Minimum="0"/>
                        <TextBlock x:Name="AktivBerletAranyText"
                                   Foreground="#00f5c4" FontSize="12" Margin="0,0,0,18"/>

                        <TextBlock Text="ELŐRE MEGVÁSÁROLT" Foreground="#3a3a4a" FontSize="10" FontWeight="SemiBold"/>
                        <ProgressBar x:Name="EloreMegvasaroltProgress"
                                     Height="6" Margin="0,6,0,4" Minimum="0"/>
                        <TextBlock x:Name="EloreMegvasaroltAranyText"
                                   Foreground="#7c6af8" FontSize="12" Margin="0,0,0,18"/>

                        <TextBlock Text="LEJÁRT / INAKTÍV" Foreground="#3a3a4a" FontSize="10" FontWeight="SemiBold"/>
                        <ProgressBar x:Name="LejartBerletProgress"
                                     Height="6" Margin="0,6,0,4" Minimum="0"/>
                        <TextBlock x:Name="LejartBerletAranyText"
                                   Foreground="#f87171" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── BENT LÉVŐK TÁBLÁZAT ── -->
            <Border Grid.Row="6" Background="#0f0f1a" CornerRadius="18" Padding="22"
                    BorderBrush="#1f1f2e" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="JELENLÉT"
                                       Foreground="#00f5c4" FontSize="10" FontWeight="SemiBold"
                                       Margin="0,0,0,3"/>
                            <TextBlock Text="Jelenleg bent lévők"
                                       Foreground="#f0ede8" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <!-- LIVE badge -->
                        <Border Background="#0d1f0a" BorderBrush="#1a3a14"
                                BorderThickness="1" CornerRadius="20"
                                Padding="10,4" Margin="14,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#4ade80"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="ÉLŐ" Foreground="#4ade80"
                                           FontSize="10" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <DataGrid x:Name="BentLevokGrid"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False" Height="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="BELÉPÉS ID"  Binding="{Binding BelepesId}"  Width="*"/>
                            <DataGridTextColumn Header="TAG ID"       Binding="{Binding TagId}"      Width="*"/>
                            <DataGridTextColumn Header="NÉV"          Binding="{Binding TeljesNev}"  Width="2*"/>
                            <DataGridTextColumn Header="BELÉPETT"
                                                Binding="{Binding BelepesIdopont, StringFormat=yyyy.MM.dd HH:mm}"
                                                Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- ── UTOLSÓ BELÉPÉSEK ── -->
            <Border Grid.Row="8" Background="#0f0f1a" CornerRadius="18" Padding="22"
                    BorderBrush="#1f1f2e" BorderThickness="1">
                <StackPanel>
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="AKTIVITÁS"
                                   Foreground="#00f5c4" FontSize="10" FontWeight="SemiBold"
                                   Margin="0,0,0,3"/>
                        <TextBlock Text="Utolsó 10 belépés"
                                   Foreground="#f0ede8" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                    <DataGrid x:Name="UtolsoBelepesekGrid"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"       Binding="{Binding BelepesId}"    Width="*"/>
                            <DataGridTextColumn Header="NÉV"      Binding="{Binding TeljesNev}"    Width="2*"/>
                            <DataGridTextColumn Header="BELÉPÉS"
                                                Binding="{Binding BelepesIdopont, StringFormat=yyyy.MM.dd HH:mm}"
                                                Width="2*"/>
                            <DataGridTextColumn Header="KILÉPÉS"
                                                Binding="{Binding KilepesIdopont, StringFormat=yyyy.MM.dd HH:mm}"
                                                Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>
