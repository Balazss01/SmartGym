<Window x:Class="SmartGymAdminWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartGYM Admin"
        Height="820"
        Width="1380"
        Background="#0B1120"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="12,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#020617">
            <StackPanel Margin="16,24,16,16">
                <TextBlock Text="SmartGYM"
                           Foreground="#38BDF8"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="8,0,8,24"/>

                <Button Content="Login"
                        Style="{StaticResource SidebarButtonStyle}"
                        />

                <Button Content="Dashboard"
                        Style="{StaticResource SidebarButtonStyle}"
                        Background="#1D4ED8"
                        Click="Dashboard_Click"/>

                <Button Content="Bérletek"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="Berletek_Click"/>

                <Button Content="Belépések"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="Belepesek_Click"/>

                <Border Background="#0F172A"
                        CornerRadius="14"
                        Margin="8,24,8,0"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="Admin"
                                   Foreground="#94A3B8"
                                   FontSize="12"/>
                        <TextBlock Text="admin@smartgym.hu"
                                   Foreground="White"
                                   FontSize="14"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#111827"
                    CornerRadius="18"
                    Padding="18"
                    Margin="0,0,0,18">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="SmartGYM Admin Dashboard"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Modern admin felület"
                                   Foreground="#94A3B8"
                                   FontSize="13"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Frame x:Name="MainFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>