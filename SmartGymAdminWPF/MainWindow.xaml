<Window x:Class="SmartGymAdminWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartGYM Admin"
        Height="1020" Width="1680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Window.Resources>

        <!-- SIDEBAR NAV GOMB  (frontend: .nav-link) -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6b6760"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#131320"/>
                                <Setter Property="Foreground" Value="#f0ede8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0f0f1a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SIDEBAR KIJELENTKEZÉS  (frontend: .nav-logout) -->
        <Style x:Key="SidebarLogoutStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Foreground" Value="#f8717170"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1a0f0f"/>
                                <Setter Property="Foreground" Value="#f87171"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════ SIDEBAR ══════════
             frontend: background rgba(9,9,15,0.92), border-right 0.5px rgba(255,255,255,0.08)
        -->
        <Border x:Name="SidebarBorder"
                Visibility="Collapsed"
                Background="#09090f"
                BorderBrush="#1a1a28"
                BorderThickness="0,0,1,0">
            <Grid Margin="12,16,12,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LOGO  (frontend: .sidebar-logo + .logo-icon gradient) -->
                <StackPanel Orientation="Horizontal" Margin="8,6,8,12">
                    <Border Width="34" Height="34" CornerRadius="10" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00f5c4" Offset="0"/>
                                <GradientStop Color="#7c6af8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="SG" Foreground="#09090f" FontWeight="Bold"
                                   FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="SmartGYM"
                               Foreground="#f0ede8"
                               FontSize="15"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- DIVIDER  (frontend: border-bottom 0.5px rgba(255,255,255,0.08)) -->
                <Border Grid.Row="1" Height="1" Background="#1a1a28" Margin="8,0"/>

                <!-- SECTION LABEL  (frontend: .nav-section) -->
                <TextBlock Grid.Row="2"
                           Text="FŐMENÜ"
                           Foreground="#2e2e3e"
                           FontSize="10"
                           FontWeight="Bold"
                           Margin="10,10,0,2"/>

                <!-- NAV LINKS -->
                <StackPanel Grid.Row="4">
                    <Button Style="{StaticResource SidebarButtonStyle}" Click="Dashboard_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Click="Tagok_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◉" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Tagok" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Click="Berletek_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◈" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Bérletek" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Click="Belepesek_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="→" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Belépések" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- FOOTER: KIJELENTKEZÉS -->
                <StackPanel Grid.Row="5">
                    <Border Height="1" Background="#1a1a28" Margin="8,0,8,8"/>
                    <Button Style="{StaticResource SidebarLogoutStyle}" Click="Logout_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊗" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Kijelentkezés" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN FRAME -->
        <Grid Grid.Column="1" Background="{StaticResource BgBrush}">
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Background="{StaticResource BgBrush}"/>
        </Grid>
    </Grid>
</Window>
