<Window x:Class="SmartGymAdminWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartGym Admin"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="#0f172a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="#0f172a"
                BorderBrush="#334155"
                BorderThickness="0,0,1,0">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="SmartGym"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Admin Panel"
                               Margin="0,4,0,0"
                               Foreground="#94a3b8"
                               FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Content="Dashboard"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Dashboard_Click"/>

                    <Button Content="Tagok"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Tagok_Click"/>

                    <Button Content="Bérletek"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Berletek_Click"/>

                    <Button Content="Belépések"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Belepesek_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <Button Content="Kijelentkezés"
                            Style="{StaticResource SidebarButtonStyle}"
                            Background="#7f1d1d"
                            BorderBrush="#991b1b"
                            Click="Logout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1" Background="{StaticResource BgBrush}">
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Background="{StaticResource BgBrush}"/>
        </Grid>
    </Grid>
</Window>