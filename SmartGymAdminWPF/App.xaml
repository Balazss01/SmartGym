<Application x:Class="SmartGymAdminWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SmartGymAdminWPF"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

       
        
        <SolidColorBrush x:Key="BgBrush"           Color="#09090f"/>
        <!-- card: rgba(255,255,255,0.04) ≈ #0f0f18 -->
        <SolidColorBrush x:Key="CardBrush"          Color="#0f0f1a"/>
        <SolidColorBrush x:Key="CardAltBrush"       Color="#0c0c15"/>
        <!-- border: rgba(255,255,255,0.08) ≈ #141420 -->
        <SolidColorBrush x:Key="BorderBrushCustom"  Color="#1f1f2e"/>
        <!-- accent: #00f5c4 -->
        <SolidColorBrush x:Key="AccentBrush"        Color="#00f5c4"/>
        <!-- accent2: #7c6af8 -->
        <SolidColorBrush x:Key="Accent2Brush"       Color="#7c6af8"/>
        <!-- text: #f0ede8 -->
        <SolidColorBrush x:Key="TextBrush"          Color="#f0ede8"/>
        <!-- text-muted: rgba(240,237,232,0.4) ≈ #6b6760 -->
        <SolidColorBrush x:Key="SubTextBrush"       Color="#6b6760"/>
        <SolidColorBrush x:Key="SidebarBgBrush"     Color="#09090f"/>
        <SolidColorBrush x:Key="InputBgBrush"       Color="#0d0d15"/>

        <!-- STATUS SZÍNEK -->
        <SolidColorBrush x:Key="GreenBrush"   Color="#4ade80"/>
        <SolidColorBrush x:Key="RedBrush"     Color="#f87171"/>
        <SolidColorBrush x:Key="BlueBrush"    Color="#7c6af8"/>
        <SolidColorBrush x:Key="YellowBrush"  Color="#fbbf24"/>

        <!-- ═══════════════════════════════════════
             GRADIENT ACCENT BUTTON
             (frontend: linear-gradient(135deg, #00f5c4, #7c6af8), dark text)
        ═══════════════════════════════════════ -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#09090f"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00f5c4" Offset="0"/>
                                    <GradientStop Color="#7c6af8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GHOST/OUTLINE GOMB (sidebar toggle, frissítés stb.) -->
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6b6760"/>
            <Setter Property="BorderBrush" Value="#1f1f2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0f0f1a"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#2f2f3e"/>
                                <Setter Property="Foreground" Value="#f0ede8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════
             TEXTBOX  (frontend: rgba(255,255,255,0.05), border rgba(255,255,255,0.1))
        ═══════════════════════════════════════ -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#0f0f1a"/>
            <Setter Property="Foreground" Value="#f0ede8"/>
            <Setter Property="CaretBrush" Value="#00f5c4"/>
            <Setter Property="SelectionBrush" Value="#00f5c4"/>
            <Setter Property="BorderBrush" Value="#1f1f2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#00f5c4"/>
                                <Setter TargetName="border" Property="Background" Value="#13131f"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2f2f3e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PASSWORDBOX -->
        <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#0f0f1a"/>
            <Setter Property="Foreground" Value="#f0ede8"/>
            <Setter Property="CaretBrush" Value="#00f5c4"/>
            <Setter Property="SelectionBrush" Value="#00f5c4"/>
            <Setter Property="BorderBrush" Value="#1f1f2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#00f5c4"/>
                                <Setter TargetName="border" Property="Background" Value="#13131f"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBOBOX -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#f9fafb"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#1f1f2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="#f9fafb"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ═══════════════════════════════════════
             DATAGRID  (frontend card stílus)
        ═══════════════════════════════════════ -->
        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#0f0f1a"/>
            <Setter Property="Foreground" Value="#f0ede8"/>
            <Setter Property="RowBackground" Value="#0f0f1a"/>
            <Setter Property="AlternatingRowBackground" Value="#0c0c15"/>
            <Setter Property="BorderBrush" Value="#1f1f2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1a1a28"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeight" Value="46"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- DATAGRID COLUMN HEADER -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#09090f"/>
            <Setter Property="Foreground" Value="#6b6760"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#1f1f2e"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <!-- DATAGRID ROW -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0d2520"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#131320"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DATAGRID CELL -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#00f5c4"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CHECKBOX -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#6b6760"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- PROGRESSBAR  (frontend: accent gradient) -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#1a1a28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Indicator" CornerRadius="3" HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00f5c4" Offset="0"/>
                                        <GradientStop Color="#7c6af8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CONVERTERS -->
        <local:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter"/>
        <local:BelepesStatusConverter x:Key="BelepesStatusConverter"/>

    </Application.Resources>
</Application>
