@page
@model GymFrontend.Pages.SzekrenyFoglalasModel

<style>
    .page-header {
        margin-bottom: 32px;
    }

    .page-tag {
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #00f5c4;
        margin-bottom: 8px;
        display: block;
    }

    .page-title {
        font-family: 'Syne', sans-serif;
        font-size: 26px;
        font-weight: 700;
        color: #f0ede8;
        margin: 0;
    }

    .alert-banner {
        display: flex;
        align-items: center;
        gap: 10px;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 13.5px;
        margin-bottom: 20px;
    }

    .alert-success {
        background: rgba(0, 245, 196, 0.08);
        border: 0.5px solid rgba(0, 245, 196, 0.25);
        color: #00f5c4;
    }

    .alert-danger {
        background: rgba(239, 68, 68, 0.08);
        border: 0.5px solid rgba(239, 68, 68, 0.25);
        color: #f87171;
    }

    .legend {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 24px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 12.5px;
        color: rgba(240, 237, 232, 0.5);
    }

    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }

        .legend-dot.szabad {
            background: #00f5c4;
        }

        .legend-dot.foglalt {
            background: rgba(239, 68, 68, 0.7);
        }

    .szekreny-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
        gap: 12px;
    }

    .szekreny-btn {
        width: 100%;
        padding: 20px 10px;
        border: 0.5px solid;
        border-radius: 16px;
        color: white;
        font-weight: 700;
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        position: relative;
        overflow: hidden;
    }

        .szekreny-btn.szabad {
            background: rgba(0, 245, 196, 0.08);
            border-color: rgba(0, 245, 196, 0.3);
            color: #00f5c4;
        }

            .szekreny-btn.szabad:hover {
                background: rgba(0, 245, 196, 0.18);
                border-color: rgba(0, 245, 196, 0.55);
                transform: translateY(-3px);
            }

        .szekreny-btn.foglalt {
            background: rgba(239, 68, 68, 0.07);
            border-color: rgba(239, 68, 68, 0.25);
            color: #f87171;
            cursor: not-allowed;
            opacity: 0.7;
        }

        .szekreny-btn.sajat {
            background: rgba(124, 106, 248, 0.12);
            border-color: rgba(124, 106, 248, 0.4);
            color: #a89cf7;
            cursor: pointer;
            opacity: 1;
        }

            .szekreny-btn.sajat:hover {
                background: rgba(124, 106, 248, 0.22);
                border-color: rgba(124, 106, 248, 0.6);
                transform: translateY(-3px);
            }

        .szekreny-btn:active {
            transform: scale(0.96);
        }

    .szekreny-szam {
        font-size: 18px;
        font-weight: 700;
    }

    .szekreny-allapot {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        opacity: 0.85;
    }

    .szekreny-ikon {
        font-size: 20px;
        line-height: 1;
    }
</style>

<div class="page-header">
    <span class="page-tag">Tárolás</span>
    <h1 class="page-title">Szekrényfoglalás</h1>
</div>

@if (TempData["Siker"] != null)
{
    <div class="alert-banner alert-success">
        <i class="bi bi-check-circle-fill"></i>
        @TempData["Siker"]
    </div>
}

@if (TempData["Hiba"] != null)
{
    <div class="alert-banner alert-danger">
        <i class="bi bi-exclamation-circle-fill"></i>
        @TempData["Hiba"]
    </div>
}

<div class="legend">
    <div class="legend-item">
        <div class="legend-dot szabad"></div>
        Szabad – kattints a foglaláshoz
    </div>
    <div class="legend-item">
        <div class="legend-dot foglalt"></div>
        Foglalt
    </div>
</div>

<div class="szekreny-grid">
    @foreach (var sz in Model.Szekrenyek)
    {
        // Feltételezzük, hogy van egy 'Sajat' bool tulajdonság a modellben,
        // vagy összehasonlítjuk a bejelentkezett felhasználó ID-jával
        var isSajat = sz.Foglalt && sz.FelhasznaloId == Model.AktualisFelhasznaloId;

        var allapotClass = isSajat ? "sajat" : (sz.Foglalt ? "foglalt" : "szabad");
        var allapotSzoveg = isSajat ? "Saját / Leadás" : (sz.Foglalt ? "Foglalt" : "Szabad");
        var ikon = isSajat ? "bi-person-check-fill" : (sz.Foglalt ? "bi-lock-fill" : "bi-unlock-fill");

        // A gomb csak akkor legyen 'disabled', ha foglalt ÉS nem a miénk
        var isDisabled = sz.Foglalt && !isSajat;

        <form method="post" asp-page-handler="Toggle">
            <input type="hidden" name="szekrenyId" value="@sz.SzekrenyId" />
            <button type="submit"
                    class="szekreny-btn @allapotClass"
                    @(isDisabled ? "disabled" : "")>
                <i class="bi @ikon szekreny-ikon"></i>
                <span class="szekreny-szam">#@sz.SzekrenySzam</span>
                <span class="szekreny-allapot">@allapotSzoveg</span>
            </button>
        </form>
    }
</div>
