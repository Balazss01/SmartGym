@page
@model GymFrontend.Pages.SzekrenyFoglalasModel

<h2>Szekrények</h2>

@if (TempData["Siker"] != null)
{
    <div style="color: green; margin-bottom: 10px;">
        @TempData["Siker"]
    </div>
}

@if (TempData["Hiba"] != null)
{
    <div style="color: red; margin-bottom: 10px;">
        @TempData["Hiba"]
    </div>
}

<div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap:15px;">
    @foreach (var sz in Model.Szekrenyek)
    {
        <form method="post" asp-page-handler="Toggle">
            <input type="hidden" name="szekrenyId" value="@sz.SzekrenyId" />

            <button type="submit"
                    style="
                            width:100%;
                            padding:25px;
                            border:none;
                            border-radius:12px;
                            color:white;
                            font-weight:bold;
                            font-size:16px;
                            cursor:pointer;
                            transition:0.2s;
                            @(sz.Foglalt ? "background:red;" : "background:green;")">

                <div>#@sz.SzekrenySzam</div>

                <div style="margin-top:10px; font-size:14px;">
                    @(sz.Foglalt ? "Foglalt" : "Szabad")
                </div>

            </button>
        </form>
    }
</div>