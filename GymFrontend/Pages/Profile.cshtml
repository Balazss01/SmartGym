@page
@model ProfileModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.1);
        transition: all 0.25s ease;
    }

        .glass-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        }

    .form-control {
        background: rgba(255,255,255,0.08);
        border: none;
        color: white;
    }

        .form-control:focus {
            background: rgba(255,255,255,0.12);
            color: white;
            box-shadow: 0 0 8px #6c63ff;
        }

    .input-group-text {
        background: rgba(255,255,255,0.08);
        border: none;
        color: #aaa;
    }

    .btn-modern {
        background: linear-gradient(45deg, #6c63ff, #00c6ff);
        border: none;
        transition: 0.2s;
    }

        .btn-modern:hover {
            transform: scale(1.03);
            box-shadow: 0 0 12px #6c63ff;
        }


    .card-anim {
        opacity: 0;
        transform: scale(0.97);
        animation: smoothIn 0.35s ease forwards;
    }

    @@keyframes smoothIn {
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="glass-card p-4 shadow-lg card-anim">

                <h3 class="text-center mb-4">Profil</h3>

                <form method="post">

                    <div class="mb-3 input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input asp-for="Vezeteknev" placeholder="Vezetéknév" class="form-control" />
                    </div>

                    <div class="mb-3 input-group">
                        <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
                        <input asp-for="Keresztnev" placeholder="Keresztnév" class="form-control" />
                    </div>

                    <div class="mb-3 input-group">
                        <span class="input-group-text"><i class="bi bi-calendar"></i></span>
                        <input asp-for="SzuletesiDatum" id="datePicker" class="form-control" />
                    </div>

                    <div class="mb-3 input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" placeholder="Email" class="form-control" />
                    </div>

                    <button class="btn btn-modern w-100 mt-3">
                        Mentés
                    </button>

                </form>

                <div asp-validation-summary="All" class="text-danger mt-3"></div>

                <div class="d-flex justify-content-between mt-4">
                    <a href="/Dashboard" class="btn btn-outline-light">← Vissza</a>
                    <a href="/Logout" class="btn btn-danger">Kijelentkezés</a>
                </div>

            </div>

        </div>
    </div>
</div>

<!-- DATE PICKER -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
    flatpickr("#datePicker", {
        dateFormat: "Y-m-d",
        maxDate: "today"
    });
</script>