<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="utf-8" />
    <title>Gym App</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            background: #0f172a;
            color: white;
        }

        /* SIDEBAR */
        .sidebar {
            position: fixed;
            width: 250px;
            height: 100vh;
            background: #020617;
            padding: 20px;
            transition: 0.3s;
        }

            .sidebar.collapsed {
                width: 70px;
            }

            .sidebar h4 {
                color: #38bdf8;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: flex;
                align-items: center;
                gap: 10px;
                color: #94a3b8;
                text-decoration: none;
                padding: 10px;
                border-radius: 8px;
                margin-bottom: 10px;
                transition: 0.2s;
            }

                .sidebar a.active {
                    background: #1e293b;
                    color: white;
                }

                .sidebar a:hover {
                    background: #1e293b;
                    color: white;
                }

            /* COLLAPSE TEXT */
            .sidebar.collapsed span {
                display: none;
            }

        /* TOPBAR */
        .topbar {
            margin-left: 250px;
            height: 60px;
            background: #020617;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            border-bottom: 1px solid #1e293b;
            transition: 0.3s;
        }

            .topbar.collapsed {
                margin-left: 70px;
            }

        /* CONTENT */
        .content {
            margin-left: 250px;
            padding: 30px;
            transition: 0.3s;
        }

            .content.collapsed {
                margin-left: 70px;
            }

        /* BUTTON */
        .menu-btn {
            cursor: pointer;
            font-size: 20px;
        }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div id="sidebar" class="sidebar">
        <h4>🏋️ <span>GymApp</span></h4>

        <a href="/Dashboard" id="menu-dashboard">🏠 <span>Dashboard</span></a>
        <a href="/Profile" id="menu-profile">👤 <span>Profil</span></a>

        <hr />

        <a href="/Logout" class="text-danger">🚪 <span>Kijelentkezés</span></a>
    </div>

    <!-- TOPBAR -->
    <div id="topbar" class="topbar">
        <span class="menu-btn" onclick="toggleSidebar()">☰</span>
        <span>Bejelentkezve</span>
    </div>

    <!-- CONTENT -->
    <div id="content" class="content">
        @RenderBody()
    </div>

    <script>
        function toggleSidebar() {
            document.getElementById("sidebar").classList.toggle("collapsed");
            document.getElementById("topbar").classList.toggle("collapsed");
            document.getElementById("content").classList.toggle("collapsed");
        }

        // ACTIVE MENU
        const path = window.location.pathname.toLowerCase();

        if (path.includes("dashboard")) {
            document.getElementById("menu-dashboard")?.classList.add("active");
        }

        if (path.includes("profile")) {
            document.getElementById("menu-profile")?.classList.add("active");
        }
    </script>

</body>
</html>