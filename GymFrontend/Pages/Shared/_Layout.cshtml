<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Gym App</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            background: radial-gradient(circle at top, #1e293b, #020617);
            background-repeat: no-repeat;
            background-attachment: fixed;
            background-size: cover;
            color: white;
            overflow-x: hidden;
        }

        /* SIDEBAR */
        .sidebar {
            position: fixed;
            width: 260px;
            height: 100vh;
            background: rgba(2, 6, 23, 0.9);
            backdrop-filter: blur(20px);
            padding: 20px;
            transition: 0.3s;
            z-index: 1000;
        }

            .sidebar.collapsed {
                width: 75px;
            }

            .sidebar h4 {
                color: #38bdf8;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: flex;
                align-items: center;
                gap: 12px;
                color: #94a3b8;
                text-decoration: none;
                padding: 12px;
                border-radius: 10px;
                margin-bottom: 10px;
                transition: 0.2s;
            }

                .sidebar a.active,
                .sidebar a:hover {
                    background: rgba(56,189,248,0.2);
                    color: white;
                }

            .sidebar.collapsed span {
                display: none;
            }

        /* TOPBAR */
        .topbar {
            margin-left: 260px;
            height: 60px;
            background: rgba(2, 6, 23, 0.8);
            backdrop-filter: blur(15px);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            transition: 0.3s;
        }

            .topbar.collapsed {
                margin-left: 75px;
            }

        /* TOPBAR BUTTONS */
        .topbar-actions {
            display: flex;
            gap: 10px;
        }

        .icon-btn {
            background: rgba(255,255,255,0.05);
            border: none;
            color: white;
            padding: 8px 10px;
            border-radius: 10px;
            transition: 0.2s;
        }

            .icon-btn:hover {
                background: rgba(56,189,248,0.3);
                transform: scale(1.1);
            }

        /* CONTENT */
        .content {
            margin-left: 260px;
            padding: 25px;
            transition: 0.3s;
        }

            .content.collapsed {
                margin-left: 75px;
            }

        /* MOBILE */
        @@media (max-width: 768px) {

            .sidebar {
                transform: translateX(-100%);
            }

                .sidebar.open {
                    transform: translateX(0);
                }

            .topbar, .content {
                margin-left: 0 !important;
            }
        }

        /* OVERLAY */
        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            display: none;
            z-index: 999;
        }

            .overlay.active {
                display: block;
            }

        .menu-btn {
            cursor: pointer;
            font-size: 22px;
        }

        .notification-wrapper {
            position: relative;
        }

        .badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: red;
            color: white;
            font-size: 10px;
            padding: 3px 6px;
            border-radius: 50%;
        }

        .notification-dropdown {
            position: absolute;
            right: 0;
            top: 45px;
            width: 260px;
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(15px);
            border-radius: 12px;
            padding: 10px;
            display: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            animation: fadeIn 0.2s ease;
            z-index: 2000;
        }

        .notification-item {
            padding: 10px;
            border-radius: 8px;
            transition: 0.2s;
            cursor: pointer;
        }

            .notification-item:hover {
                background: rgba(56,189,248,0.2);
            }

        .notification-empty {
            text-align: center;
            font-size: 12px;
            color: #94a3b8;
            margin-top: 5px;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .notification-wrapper,
        .profile-wrapper {
            position: relative;
        }

        .badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: red;
            font-size: 10px;
            padding: 3px 6px;
            border-radius: 50%;
        }

        .notification-dropdown,
        .profile-dropdown {
            position: absolute;
            right: 0;
            top: 50px;
            width: 240px;
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(15px);
            border-radius: 12px;
            padding: 10px;
            display: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            z-index: 2000;

        }

        

        .notification-item {
            padding: 10px;
            border-radius: 8px;
            transition: 0.2s;
        }

            .notification-item:hover {
                background: rgba(56,189,248,0.2);
            }

        .profile-info {
            padding: 10px;
        }

            .profile-info small {
                color: #94a3b8;
            }

        .dropdown-item {
            display: block;
            padding: 10px;
            border-radius: 8px;
            color: white;
            text-decoration: none;
            transition: 0.2s;
        }

        .dropdown-item:hover {
                background: rgba(56,189,248,0.2);
            }

        .topbar-actions {
            display: flex !important;
            gap: 10px;
        }

        
        .topbar {
            position: relative;
            z-index: 2000;
        }

       
        .notification-dropdown,
        .profile-dropdown {
            z-index: 3000 !important;
        }

       
        .hero {
            position: relative;
            z-index: 1;
        }

        .topbar {
            color: white !important;
        }

            .topbar i {
                color: white !important;
            }

            .topbar .icon-btn {
                color: white !important;
            }

                .topbar .icon-btn:hover {
                    color: white !important;
                }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div id="sidebar" class="sidebar">
        <h4><i class="bi bi-fire"></i> <span>SmartGYM</span></h4>

        <a href="/Dashboard" id="menu-dashboard">
            <i class="bi bi-speedometer2"></i>
            <span>Dashboard</span>
        </a>

        <a href="/Berletek">
            <i class="bi bi-calendar-plus"></i>
            <span>Bérletek</span>
        </a>
            
        <a href="/SajatBerletek">
            <i class="bi bi-calendar"></i>
            <span>Saját bérletek</span>
        </a>

        <a href="/Profile" id="menu-profile">
            <i class="bi bi-person-circle"></i>
            <span>Profil</span>
        </a>

        <hr />

        <a href="/Logout" class="text-danger">
            <i class="bi bi-box-arrow-right"></i>
            <span>Kijelentkezés</span>
        </a>
    </div>

    <!-- OVERLAY (mobilhoz) -->
    <div id="overlay" class="overlay" onclick="closeSidebar()"></div>

    <!-- TOPBAR -->
    <!-- TOPBAR -->
    <div id="topbar" class="topbar">

        <span class="menu-btn" onclick="toggleSidebar()">
            <i class="bi bi-list"></i>
        </span>

        <div class="topbar-actions">

            <!-- Értesítés rész -->
            <div class="notification-wrapper">
                <button class="icon-btn position-relative" onclick="toggleNotifications()">
                    <i class="bi bi-bell"></i>
                    <span class="badge">3</span>
                </button>

                <div id="notificationDropdown" class="notification-dropdown">
                    <div class="notification-item">💪 Új edzés</div>
                    <div class="notification-item">📅 Bérlet lejár</div>
                </div>
            </div>

            <!-- Profil rész -->
            <div class="profile-wrapper">
                <button class="icon-btn" onclick="toggleProfileMenu()">
                    <i class="bi bi-person-circle"></i>
                </button>

                <div id="profileDropdown" class="profile-dropdown">
                    <div class="profile-info">
                        <strong>Felhasználó</strong>
                        <small>email@email.com</small>
                    </div>

                    <hr />

                    <a href="/Profile" class="dropdown-item">
                        <i class="bi bi-person"></i> Profil
                    </a>

                    <a href="/Logout" class="dropdown-item text-danger">
                        <i class="bi bi-box-arrow-right"></i> Kijelentkezés
                    </a>
                </div>
            </div>

        </div>
    </div>

    <!-- CONTENT -->
    <div id="content" class="content">
        @RenderBody()
    </div>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const overlay = document.getElementById("overlay");

            if (window.innerWidth <= 768) {
                sidebar.classList.toggle("open");
                overlay.classList.toggle("active");
            } else {
                sidebar.classList.toggle("collapsed");
                document.getElementById("topbar").classList.toggle("collapsed");
                document.getElementById("content").classList.toggle("collapsed");
            }
        }

        function closeSidebar() {
            document.getElementById("sidebar").classList.remove("open");
            document.getElementById("overlay").classList.remove("active");
        }

        const path = window.location.pathname.toLowerCase();

        if (path.includes("dashboard")) {
            document.getElementById("menu-dashboard")?.classList.add("active");
        }

        if (path.includes("profile")) {
            document.getElementById("menu-profile")?.classList.add("active");
        }

         

        
        document.addEventListener("click", function (e) {
            const dropdown = document.getElementById("notificationDropdown");
            const wrapper = document.querySelector(".notification-wrapper");

            if (!wrapper.contains(e.target)) {
                dropdown.style.display = "none";
            }
        });
                function toggleNotifications() {
            const n = document.getElementById("notificationDropdown");
            const p = document.getElementById("profileDropdown");

            p.style.display = "none";
            n.style.display = n.style.display === "block" ? "none" : "block";
        }

        function toggleProfileMenu() {
            const p = document.getElementById("profileDropdown");
            const n = document.getElementById("notificationDropdown");

            n.style.display = "none";
            p.style.display = p.style.display === "block" ? "none" : "block";
        }


        document.addEventListener("click", function (e) {
            const notif = document.querySelector(".notification-wrapper");
            const profile = document.querySelector(".profile-wrapper");

            if (!notif.contains(e.target)) {
                document.getElementById("notificationDropdown").style.display = "none";
            }

            if (!profile.contains(e.target)) {
                document.getElementById("profileDropdown").style.display = "none";
            }
        });
        const count = document.querySelectorAll(".notification-item").length;
        document.querySelector(".badge").innerText = count;
    </script>

</body>
</html>