@using Microsoft.AspNetCore.Http
@using System.Text
@using System.Text.Json
@{
    var token = Context.Session.GetString("JWT");
    var bejelentkezve = !string.IsNullOrEmpty(token);

    bool bentVan = false;
    string teljesNev = "Felhasználó";
    string nevInitials = "FH";

    if (!string.IsNullOrEmpty(token))
    {
        try
        {
            // JWT payload manuális dekódolása — nincs szükség külső NuGet csomagra
            var jwtParts = token.Split('.');
            if (jwtParts.Length == 3)
            {
                var padded = jwtParts[1].Replace('-', '+').Replace('_', '/');
                switch (padded.Length % 4)
                {
                    case 2: padded += "=="; break;
                    case 3: padded += "="; break;
                }
                var payloadJson = Encoding.UTF8.GetString(Convert.FromBase64String(padded));
                var doc = JsonDocument.Parse(payloadJson).RootElement;

                string nev = null;
                foreach (var ct in new[] {
                    "name",
                    "unique_name",
                    "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name"
                })
                {
                    if (doc.TryGetProperty(ct, out var val))
                    {
                        nev = val.GetString();
                        break;
                    }
                }

                if (!string.IsNullOrEmpty(nev))
                {
                    teljesNev = nev;
                    var nameParts = nev.Trim().Split(new char[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
                    nevInitials = nameParts.Length >= 2
                        ? ("" + nameParts[0][0] + nameParts[nameParts.Length - 1][0]).ToUpper()
                        : nev.Substring(0, Math.Min(2, nev.Length)).ToUpper();
                }
            }
        }
        catch { }
    }

    if (!string.IsNullOrEmpty(token))
    {
        try
        {
            using var client = new HttpClient();
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var res = client.GetAsync("https://localhost:7270/api/Belepesek/statusz").Result;

            if (res.IsSuccessStatusCode)
            {
                var json = res.Content.ReadAsStringAsync().Result;
                var data = System.Text.Json.JsonDocument.Parse(json).RootElement;

                if (data.TryGetProperty("bentVan", out var bent))
                {
                    bentVan = bent.GetBoolean();
                }
            }
        }
        catch { }
    }
}

<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SmartGYM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --sidebar-w: 240px;
            --sidebar-collapsed-w: 64px;
            --topbar-h: 54px;
            --accent: #00f5c4;
            --accent2: #7c6af8;
            --accent-glow: rgba(0, 245, 196, 0.15);
            --bg: #09090f;
            --bg-card: rgba(255,255,255,0.04);
            --bg-card-hover: rgba(255,255,255,0.07);
            --border: rgba(255,255,255,0.08);
            --border-hover: rgba(255,255,255,0.15);
            --text: #f0ede8;
            --text-muted: rgba(240,237,232,0.4);
            --font-head: 'Syne', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --radius: 12px;
            --radius-sm: 8px;
            --transition: 0.25s cubic-bezier(.4,0,.2,1);
        }

        html, body {
            height: 100%;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-body);
            font-size: 14px;
            line-height: 1.6;
            overflow-x: hidden;
        }

            /* Background orbs */
            body::before, body::after {
                content: '';
                position: fixed;
                border-radius: 50%;
                pointer-events: none;
                z-index: 0;
                filter: blur(100px);
            }

            body::before {
                width: 500px;
                height: 500px;
                background: rgba(0, 245, 196, 0.04);
                top: -150px;
                left: -50px;
            }

            body::after {
                width: 400px;
                height: 400px;
                background: rgba(124, 106, 248, 0.06);
                bottom: -100px;
                right: -50px;
            }

        /* ── SIDEBAR ── */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-w);
            height: 100vh;
            background: rgba(9, 9, 15, 0.92);
            backdrop-filter: blur(24px);
            border-right: 0.5px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 16px 12px;
            transition: width var(--transition);
            z-index: 1000;
            overflow: hidden;
        }

            .sidebar.collapsed {
                width: var(--sidebar-collapsed-w);
            }

        /* Logo */
        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 8px 16px;
            border-bottom: 0.5px solid var(--border);
            margin-bottom: 8px;
            text-decoration: none;
            flex-shrink: 0;
        }

        .logo-icon {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .logo-label {
            font-family: var(--font-head);
            font-size: 15px;
            font-weight: 700;
            letter-spacing: 0.06em;
            color: var(--text);
            white-space: nowrap;
        }

        .sidebar.collapsed .logo-label,
        .sidebar.collapsed .nav-label,
        .sidebar.collapsed .nav-badge,
        .sidebar.collapsed .nav-section,
        .sidebar.collapsed .user-info,
        .sidebar.collapsed .sidebar-divider {
            opacity: 0;
            pointer-events: none;
        }

        /* Nav sections */
        .nav-section {
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--text-muted);
            padding: 10px 10px 4px;
            white-space: nowrap;
            transition: opacity var(--transition);
        }

        /* Nav links */
        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 10px;
            border-radius: var(--radius-sm);
            color: var(--text-muted);
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 400;
            transition: all 0.2s;
            margin-bottom: 2px;
            white-space: nowrap;
            position: relative;
        }

            .nav-link:hover {
                background: var(--bg-card-hover);
                color: var(--text);
            }

            .nav-link.active {
                background: var(--accent-glow);
                color: var(--text);
            }

                .nav-link.active::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 20%;
                    bottom: 20%;
                    width: 3px;
                    background: linear-gradient(to bottom, var(--accent), var(--accent2));
                    border-radius: 0 3px 3px 0;
                }

            .nav-link.nav-logout {
                color: rgba(248, 113, 113, 0.7);
            }

                .nav-link.nav-logout:hover {
                    background: rgba(248, 113, 113, 0.1);
                    color: #f87171;
                }

            .nav-link.nav-login {
                color: var(--accent);
            }

                .nav-link.nav-login:hover {
                    background: var(--accent-glow);
                    color: var(--accent);
                }

            .nav-link.nav-register {
                color: #4ade80;
            }

                .nav-link.nav-register:hover {
                    background: rgba(74, 222, 128, 0.1);
                    color: #4ade80;
                }

        .nav-icon {
            width: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 15px;
        }

        .nav-badge {
            margin-left: auto;
            background: rgba(0,245,196,0.15);
            color: var(--accent);
            font-size: 10px;
            padding: 2px 7px;
            border-radius: 20px;
            font-weight: 500;
            flex-shrink: 0;
        }

        .sidebar-divider {
            height: 0.5px;
            background: var(--border);
            margin: 8px 0;
            transition: opacity var(--transition);
        }

        /* Sidebar footer user card */
        .sidebar-footer {
            margin-top: auto;
            padding-top: 10px;
            border-top: 0.5px solid var(--border);
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: background 0.2s;
            text-decoration: none;
        }

            .user-card:hover {
                background: var(--bg-card-hover);
            }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 9px;
            background: linear-gradient(135deg, var(--accent2), #3a2fb8);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 500;
            color: #fff;
            flex-shrink: 0;
        }

        .user-info {
            overflow: hidden;
        }

        .user-name {
            font-size: 13px;
            font-weight: 500;
            color: var(--text);
            white-space: nowrap;
        }

        .user-status {
            font-size: 11px;
            color: var(--accent);
            white-space: nowrap;
        }

        /* ── TOPBAR ── */
        .topbar {
            position: fixed;
            top: 0;
            left: var(--sidebar-w);
            right: 0;
            height: var(--topbar-h);
            background: rgba(9, 9, 15, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 0.5px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 20px;
            gap: 12px;
            z-index: 900;
            transition: left var(--transition);
        }

            .topbar.collapsed {
                left: var(--sidebar-collapsed-w);
            }

        .toggle-btn {
            width: 32px;
            height: 32px;
            border-radius: var(--radius-sm);
            background: none;
            border: 0.5px solid var(--border);
            color: var(--text-muted);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            transition: all 0.2s;
            flex-shrink: 0;
        }

            .toggle-btn:hover {
                background: var(--bg-card-hover);
                color: var(--text);
                border-color: var(--border-hover);
            }

        .topbar-title {
            font-family: var(--font-head);
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
        }

        .topbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-pill {
            height: 30px;
            padding: 0 12px;
            border-radius: 20px;
            background: rgba(0,245,196,0.1);
            border: 0.5px solid rgba(0,245,196,0.3);
            color: var(--accent);
            font-size: 12px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: default;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--accent);
            animation: blink 2s infinite;
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.3;
            }
        }

        .icon-btn {
            width: 34px;
            height: 34px;
            border-radius: var(--radius-sm);
            background: none;
            border: 0.5px solid var(--border);
            color: var(--text-muted);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            transition: all 0.2s;
            position: relative;
        }

            .icon-btn:hover {
                background: var(--bg-card-hover);
                color: var(--text);
                border-color: var(--border-hover);
            }

        .notif-badge {
            position: absolute;
            top: 4px;
            right: 4px;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--accent);
            border: 1.5px solid var(--bg);
        }

        /* Dropdowns */
        .dropdown-wrapper {
            position: relative;
        }

        .dropdown-menu-custom {
            position: absolute;
            right: 0;
            top: calc(100% + 10px);
            width: 220px;
            background: rgba(12, 12, 20, 0.97);
            backdrop-filter: blur(20px);
            border: 0.5px solid var(--border);
            border-radius: var(--radius);
            padding: 8px;
            display: none;
            z-index: 9999;
            box-shadow: 0 16px 40px rgba(0,0,0,0.5);
        }

            .dropdown-menu-custom.show {
                display: block;
            }

        .dropdown-header {
            padding: 8px 10px 10px;
            border-bottom: 0.5px solid var(--border);
            margin-bottom: 6px;
        }

            .dropdown-header strong {
                font-size: 13px;
                font-weight: 500;
                color: var(--text);
            }

            .dropdown-header small {
                font-size: 11px;
                color: var(--text-muted);
                display: block;
                margin-top: 2px;
            }

        .dropdown-item-custom {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 8px 10px;
            border-radius: var(--radius-sm);
            color: var(--text-muted);
            text-decoration: none;
            font-size: 13px;
            transition: all 0.15s;
        }

            .dropdown-item-custom:hover {
                background: var(--bg-card-hover);
                color: var(--text);
            }

            .dropdown-item-custom.danger {
                color: rgba(248,113,113,0.7);
            }

                .dropdown-item-custom.danger:hover {
                    background: rgba(248,113,113,0.1);
                    color: #f87171;
                }

        .notif-item {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            padding: 8px 10px;
            border-radius: var(--radius-sm);
            font-size: 12.5px;
            color: var(--text-muted);
            transition: background 0.15s;
            cursor: default;
        }

            .notif-item:hover {
                background: var(--bg-card-hover);
            }

        .notif-icon {
            font-size: 14px;
            flex-shrink: 0;
            margin-top: 1px;
        }

        /* ── CONTENT ── */
        .content {
            margin-left: var(--sidebar-w);
            margin-top: var(--topbar-h);
            padding: 28px;
            min-height: calc(100vh - var(--topbar-h));
            transition: margin-left var(--transition);
            position: relative;
            z-index: 1;
        }

            .content.collapsed {
                margin-left: var(--sidebar-collapsed-w);
            }

        /* ── OVERLAY (mobile) ── */
        .overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            z-index: 999;
            backdrop-filter: blur(4px);
        }

            .overlay.active {
                display: block;
            }

        /* ── RESPONSIVE ── */
        @@media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
                width: var(--sidebar-w) !important;
            }

                .sidebar.open {
                    transform: translateX(0);
                }

            .topbar {
                left: 0 !important;
            }

            .content {
                margin-left: 0 !important;
            }
        }

        /* ── UTILITY ── */
        a {
            color: inherit;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div id="sidebar" class="sidebar">
        <a href="/" class="sidebar-logo">
            <span class="logo-label">SmartGYM</span>
        </a>

        <span class="nav-section">Főmenü</span>

        <a href="/Dashboard" class="nav-link" id="menu-dashboard">
            <i class="bi bi-speedometer2 nav-icon"></i>
            <span class="nav-label">Dashboard</span>
        </a>

        <a href="/Berletek" class="nav-link" id="menu-berletek">
            <i class="bi bi-calendar-plus nav-icon"></i>
            <span class="nav-label">Bérletek</span>
        </a>

        @if (bejelentkezve)
        {
            <a href="/SajatBerletek" class="nav-link" id="menu-sajatberletek">
                <i class="bi bi-calendar-check nav-icon"></i>
                <span class="nav-label">Saját bérletek</span>
            </a>

            <span class="nav-section">Gym</span>

            <a href="/Belepes" class="nav-link" id="menu-belepes">
                <i class="bi bi-box-arrow-in-right nav-icon"></i>
                <span class="nav-label">Belépés / Kilépés</span>
            </a>

            @if (bentVan)
            {
                <a href="/SzekrenyFoglalas" class="nav-link" id="menu-szekreny">
                    <i class="bi bi-lock nav-icon"></i>
                    <span class="nav-label">Szekrények</span>
                </a>
            }

            <span class="nav-section">Fiók</span>

            <a href="/Profile" class="nav-link" id="menu-profile">
                <i class="bi bi-person-circle nav-icon"></i>
                <span class="nav-label">Profil</span>
            </a>

            <div class="sidebar-divider"></div>

            <a href="/Logout" class="nav-link nav-logout">
                <i class="bi bi-box-arrow-right nav-icon"></i>
                <span class="nav-label">Kijelentkezés</span>
            </a>

            <div class="sidebar-footer">
                <a href="/Profile" class="user-card">
                    <div class="user-avatar">@nevInitials</div>
                    <div class="user-info">
                        <div class="user-name">@teljesNev</div>
                        <div class="user-status">● Aktív tag</div>
                    </div>
                </a>
            </div>
        }
        else
        {
            <div class="sidebar-divider"></div>
            <a href="/Login" class="nav-link nav-login" id="menu-login">
                <i class="bi bi-box-arrow-in-right nav-icon"></i>
                <span class="nav-label">Bejelentkezés</span>
            </a>
            <a href="/Register" class="nav-link nav-register" id="menu-register">
                <i class="bi bi-person-plus nav-icon"></i>
                <span class="nav-label">Regisztráció</span>
            </a>
        }
    </div>

    <!-- OVERLAY -->
    <div id="overlay" class="overlay" onclick="closeSidebar()"></div>

    <!-- TOPBAR -->
    <div id="topbar" class="topbar">
        <button class="toggle-btn" onclick="toggleSidebar()" aria-label="Menü">
            <i class="bi bi-list"></i>
        </button>

        <span class="topbar-title" id="topbar-page-title">SmartGYM</span>

        <div class="topbar-right">
            @if (bejelentkezve)
            {
                @if (bentVan)
                {
                    <div class="status-pill">
                        <div class="status-dot"></div>
                        Bent vagyok
                    </div>
                }

                <!-- Értesítések -->
                <div class="dropdown-wrapper">
                    <button class="icon-btn" onclick="toggleDropdown('notifDropdown')" aria-label="Értesítések">
                        <i class="bi bi-bell"></i>
                        <span class="notif-badge"></span>
                    </button>
                    <div id="notifDropdown" class="dropdown-menu-custom">
                        <div class="dropdown-header">
                            <strong>Értesítések</strong>
                            <small>2 olvasatlan</small>
                        </div>
                        <div class="notif-item">
                            <span class="notif-icon">💪</span>
                            <span>Új edzésprogram érhető el</span>
                        </div>
                        <div class="notif-item">
                            <span class="notif-icon">📅</span>
                            <span>Bérleted hamarosan lejár</span>
                        </div>
                    </div>
                </div>

                <!-- Profil -->
                <div class="dropdown-wrapper">
                    <button class="icon-btn" onclick="toggleDropdown('profileDropdown')" aria-label="Profil">
                        <i class="bi bi-person-circle"></i>
                    </button>
                    <div id="profileDropdown" class="dropdown-menu-custom">
                        <div class="dropdown-header">
                            <strong>@teljesNev</strong>
                            <small>Bejelentkezve</small>
                        </div>
                        <a href="/Profile" class="dropdown-item-custom">
                            <i class="bi bi-person"></i> Profil
                        </a>
                        <a href="/SajatBerletek" class="dropdown-item-custom">
                            <i class="bi bi-calendar-check"></i> Saját bérletek
                        </a>
                        <a href="/Logout" class="dropdown-item-custom danger">
                            <i class="bi bi-box-arrow-right"></i> Kijelentkezés
                        </a>
                    </div>
                </div>
            }
            else
            {
                <a href="/Login" class="icon-btn" style="text-decoration:none;font-size:12px;width:auto;padding:0 14px;gap:6px;color:var(--accent);border-color:rgba(0,245,196,0.3);">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Bejelentkezés</span>
                </a>
                <a href="/Register" class="icon-btn" style="text-decoration:none;font-size:12px;width:auto;padding:0 14px;gap:6px;color:#4ade80;border-color:rgba(74,222,128,0.3);">
                    <i class="bi bi-person-plus"></i>
                    <span>Regisztráció</span>
                </a>
            }
        </div>
    </div>

    <!-- CONTENT -->
    <div id="content" class="content">
        @RenderBody()
    </div>

    <script>
        // Sidebar toggle
        function toggleSidebar() {
            const sb = document.getElementById("sidebar");
            const tb = document.getElementById("topbar");
            const ct = document.getElementById("content");
            const ov = document.getElementById("overlay");

            if (window.innerWidth <= 768) {
                sb.classList.toggle("open");
                ov.classList.toggle("active");
            } else {
                sb.classList.toggle("collapsed");
                tb.classList.toggle("collapsed");
                ct.classList.toggle("collapsed");
            }
        }

        function closeSidebar() {
            document.getElementById("sidebar").classList.remove("open");
            document.getElementById("overlay").classList.remove("active");
        }

        // Dropdown toggle
        function toggleDropdown(id) {
            const all = document.querySelectorAll(".dropdown-menu-custom");
            all.forEach(d => {
                if (d.id !== id) d.classList.remove("show");
            });
            document.getElementById(id)?.classList.toggle("show");
        }

        document.addEventListener("click", function (e) {
            if (!e.target.closest(".dropdown-wrapper")) {
                document.querySelectorAll(".dropdown-menu-custom").forEach(d => d.classList.remove("show"));
            }
        });

        // Active nav link
        const path = window.location.pathname.toLowerCase();
        const pageMap = {
            "dashboard":        "menu-dashboard",
            "berletek":         "menu-berletek",
            "sajatberletek":    "menu-sajatberletek",
            "profile":          "menu-profile",
            "szekreny":         "menu-szekreny",
            "login":            "menu-login",
            "register":         "menu-register",
            "belepes":          "menu-belepes",
        };

        for (const [key, id] of Object.entries(pageMap)) {
            if (path.includes(key)) {
                document.getElementById(id)?.classList.add("active");
            }
        }

        // Topbar title from active link
        const activeLink = document.querySelector(".nav-link.active .nav-label");
        if (activeLink) {
            document.getElementById("topbar-page-title").textContent = activeLink.textContent.trim();
        }
    </script>
</body>
</html>
