@page
@model RegisterModel

<div class="container mt-5">
    <div class="col-md-6 mx-auto">

        <div class="card p-4 shadow">
            <h3>Regisztráció</h3>

            <form method="post">

                <div class="mb-3">
                    <label>Vezetéknév</label>
                    <input asp-for="Vezeteknev" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Keresztnév</label>
                    <input asp-for="Keresztnev" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Születési dátum</label>
                    <input asp-for="SzuletesiDatum" type="date" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Email</label>
                    <input asp-for="Email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Jelszó</label>
                    <input asp-for="Password" type="password" class="form-control" />
                </div>

                <button class="btn btn-success w-100">
                    Regisztráció
                </button>
            </form>

            <div asp-validation-summary="All" class="text-danger mt-3"></div>
        </div>

    </div>
</div>