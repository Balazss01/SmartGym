@page
@model GymFrontend.Pages.SajatBerletekModel

<h2 style="margin-bottom:20px;">Saját bérleteim</h2>

@if (Model.Berletek.Count == 0)
{
    <div style="padding:20px; background:#ffecec; border-radius:10px;">
        Nincs bérleted
    </div>
}
else
{
    <!-- STAT KÁRTYÁK -->
    <div style="display:flex; gap:20px; margin-bottom:30px; flex-wrap:wrap;">
        <div style="flex:1; min-width:200px; padding:20px; background:#4CAF50; color:white; border-radius:15px;">
            <h3>Aktív</h3>
            <h1>@Model.Berletek.Count(b => b.Aktiv)</h1>
        </div>

        <div style="flex:1; min-width:200px; padding:20px; background:#f44336; color:white; border-radius:15px;">
            <h3>Lejárt</h3>
            <h1>@Model.Berletek.Count(b => !b.Aktiv)</h1>
        </div>
    </div>

    <!-- TÁBLA -->
    <table style="width:100%; border-collapse:collapse; background:white; border-radius:10px; overflow:hidden; color:black;">
        <thead style="background:#222; color:white;">
            <tr>
                <th>Típus</th>
                <th>Kezdet</th>
                <th>Vége</th>
                <th>Állapot</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model.Berletek)
            {
                <tr style="border-bottom:1px solid #eee;">
                    <td>@b.BerletTipusNev</td>
                    <td>@b.KezdetDatum.ToString("yyyy.MM.dd")</td>
                    <td>@b.VegeDatum.ToString("yyyy.MM.dd")</td>
                    <td>
                        @if (b.Aktiv)
                        {
                            <span style="color:#4CAF50; font-weight:bold;">Aktív</span>
                        }
                        else
                        {
                            <span style="color:#f44336;">Lejárt</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}