@page
@model IndexModel

<style>
    .hero {
        position: relative;
        min-height: calc(100vh - 54px);
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    .hero-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
        opacity: 0.35;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 60% 50%, rgba(0,245,196,0.07) 0%, transparent 60%), radial-gradient(ellipse at 30% 80%, rgba(124,106,248,0.08) 0%, transparent 50%), linear-gradient(to right, rgba(9,9,15,0.85) 0%, rgba(9,9,15,0.4) 100%);
        z-index: 1;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 520px;
        margin-left: auto;
        margin-right: 6%;
        padding: 40px 0;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: rgba(0,245,196,0.1);
        border: 0.5px solid rgba(0,245,196,0.25);
        border-radius: 20px;
        padding: 5px 14px;
        font-size: 12px;
        color: #00f5c4;
        letter-spacing: 0.08em;
        font-weight: 500;
        margin-bottom: 22px;
    }

    .hero-eyebrow-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #00f5c4;
        animation: blink 2s infinite;
    }

    @@keyframes blink {
        0%, 100%

    {
        opacity: 1;
    }

    50% {
        opacity: 0.3;
    }

    }

    .hero-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2.4rem, 5vw, 3.6rem);
        font-weight: 700;
        line-height: 1.1;
        color: #f0ede8;
        margin-bottom: 18px;
    }

        .hero-title .accent {
            background: linear-gradient(135deg, #00f5c4, #7c6af8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

    .hero-desc {
        font-size: 15px;
        color: rgba(240,237,232,0.5);
        line-height: 1.7;
        margin-bottom: 32px;
        max-width: 400px;
    }

    .hero-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 40px;
    }

    .btn-primary-custom {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 13px 24px;
        background: linear-gradient(135deg, #00f5c4, #7c6af8);
        border: none;
        border-radius: 12px;
        color: #09090f;
        font-family: 'Syne', sans-serif;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-decoration: none;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
    }

        .btn-primary-custom:hover {
            opacity: 0.88;
            transform: translateY(-2px);
            color: #09090f;
        }

        .btn-primary-custom:active {
            transform: scale(0.97);
        }

    .btn-ghost-custom {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 22px;
        background: rgba(255,255,255,0.05);
        border: 0.5px solid rgba(255,255,255,0.12);
        border-radius: 12px;
        color: rgba(240,237,232,0.7);
        font-size: 14px;
        font-weight: 400;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-ghost-custom:hover {
            background: rgba(255,255,255,0.09);
            border-color: rgba(255,255,255,0.22);
            color: #f0ede8;
        }

    /* Stats row */
    .hero-stats {
        display: flex;
        gap: 28px;
        flex-wrap: wrap;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .stat-number {
        font-family: 'Syne', sans-serif;
        font-size: 22px;
        font-weight: 700;
        color: #f0ede8;
        line-height: 1;
    }

    .stat-label {
        font-size: 11px;
        color: rgba(240,237,232,0.35);
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .stat-divider {
        width: 0.5px;
        background: rgba(255,255,255,0.1);
        align-self: stretch;
    }

    /* Feature cards */
    .features {
        padding: 80px 28px;
        position: relative;
        z-index: 2;
    }

    .features-header {
        text-align: center;
        margin-bottom: 48px;
    }

    .section-tag {
        display: inline-block;
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #00f5c4;
        margin-bottom: 12px;
    }

    .section-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        font-weight: 700;
        color: #f0ede8;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 16px;
        max-width: 900px;
        margin: 0 auto;
    }

    .feature-card {
        background: rgba(255,255,255,0.04);
        border: 0.5px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        padding: 24px;
        transition: all 0.25s;
        position: relative;
        overflow: hidden;
    }

        .feature-card::before {
            content: '';
            position: absolute;
            top: -40px;
            left: -40px;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            filter: blur(40px);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .feature-card:hover {
            background: rgba(255,255,255,0.07);
            border-color: rgba(255,255,255,0.14);
            transform: translateY(-3px);
        }

            .feature-card:hover::before {
                opacity: 1;
            }

        .feature-card.c1::before {
            background: rgba(0,245,196,0.2);
        }

        .feature-card.c2::before {
            background: rgba(124,106,248,0.2);
        }

        .feature-card.c3::before {
            background: rgba(0,245,196,0.15);
        }

    .feature-icon {
        width: 42px;
        height: 42px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        margin-bottom: 16px;
    }

        .feature-icon.teal {
            background: rgba(0,245,196,0.12);
        }

        .feature-icon.purple {
            background: rgba(124,106,248,0.12);
        }

        .feature-icon.green {
            background: rgba(74,222,128,0.12);
        }

    .feature-title {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 600;
        color: #f0ede8;
        margin-bottom: 8px;
    }

    .feature-desc {
        font-size: 13px;
        color: rgba(240,237,232,0.45);
        line-height: 1.65;
    }

    @@media (max-width: 768px) {
        .hero-content

    {
        margin: 0 auto;
        padding: 40px 20px;
        text-align: center;
    }

    .hero-desc {
        margin-left: auto;
        margin-right: auto;
    }

    .hero-actions {
        justify-content: center;
    }

    .hero-stats {
        justify-content: center;
    }

    .hero-eyebrow {
        margin-left: auto;
        margin-right: auto;
    }

    }
</style>

<!-- HERO -->
<div class="hero">
    <video class="hero-video" autoplay muted loop playsinline>
        <source src="/videos/konditerem1.mp4" type="video/mp4">
    </video>
    <div class="hero-overlay"></div>

    <div class="hero-content">
        <div class="hero-eyebrow">
            <div class="hero-eyebrow-dot"></div>
            Modern edzés élmény
        </div>

        <h1 class="hero-title">
            Edzz okosabban<br>
            a <span class="accent">SmartGYM</span><br>
            segítségével
        </h1>

        <p class="hero-desc">
            Bérletek, szekrényfoglalás és belépéskezelés — minden egy helyen,
            egyszerűen és gyorsan.
        </p>

        <div class="hero-actions">
            <a href="/Register" class="btn-primary-custom">
                <i class="bi bi-arrow-right"></i>
                Kezdés most
            </a>
            <a href="/Berletek" class="btn-ghost-custom">
                <i class="bi bi-calendar-plus"></i>
                Bérletek
            </a>
        </div>

        <div class="hero-stats">
            <div class="stat-item">
                <span class="stat-number">500+</span>
                <span class="stat-label">Aktív tag</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-number">24/7</span>
                <span class="stat-label">Nyitvatartás</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-number">3 perc</span>
                <span class="stat-label">Regisztráció</span>
            </div>
        </div>
    </div>
</div>

<!-- FEATURES -->
<div class="features">
    <div class="features-header">
        <div class="section-tag">Miért SmartGYM?</div>
        <h2 class="section-title">Minden, amire szükséged van</h2>
    </div>

    <div class="features-grid">
        <div class="feature-card c1">
            <div class="feature-icon teal">
                <i class="bi bi-calendar-check" style="color:#00f5c4;"></i>
            </div>
            <div class="feature-title">Rugalmas bérletek</div>
            <div class="feature-desc">Napi, heti és havi bérletek — válaszd azt, ami illik az életstílusodhoz.</div>
        </div>

        <div class="feature-card c2">
            <div class="feature-icon purple">
                <i class="bi bi-lock" style="color:#7c6af8;"></i>
            </div>
            <div class="feature-title">Szekrényfoglalás</div>
            <div class="feature-desc">Foglalj szekrényt előre, hogy minden az edzésen legyen a fejedben.</div>
        </div>

        <div class="feature-card c3">
            <div class="feature-icon green">
                <i class="bi bi-box-arrow-in-right" style="color:#4ade80;"></i>
            </div>
            <div class="feature-title">Okos belépés</div>
            <div class="feature-desc">QR-kódos be- és kilépés, valós idejű jelenlét követéssel.</div>
        </div>
    </div>
</div>
