@page
@model GymFrontend.Pages.BelepesModel

<div class="belepes-wrapper">
    <div class="belepes-card">
        <h2>Konditerem belépés</h2>

        @if (TempData["Siker"] != null)
        {
            <div class="alert-box success">@TempData["Siker"]</div>
        }

        @if (TempData["Hiba"] != null)
        {
            <div class="alert-box error">@TempData["Hiba"]</div>
        }

        @if (!Model.BentVan)
        {
            <div class="status-box kint">
                <div class="status-title">Jelenleg nem vagy bent</div>
                <div class="status-text">A belépés gombra kattintva elindíthatod a belépést.</div>
            </div>

            <form method="post" asp-page-handler="Belep">
                <button type="submit" class="main-btn belep-btn">
                    Belépés
                </button>
            </form>

            <script>
                sessionStorage.removeItem("qrLejart");
            </script>
        }
        else
        {
            <div id="qrSection" style="display:none;">
                <div class="status-box bent">
                    <div class="status-title">Belépés folyamatban</div>
                    <div class="status-text">Mutasd fel a QR-kódot a beléptető kapunál.</div>
                </div>

                <div class="qr-box">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=SmartGYM-Belepes" alt="QR kód" />
                    <p class="qr-text">Beléptető QR-kód</p>
                    <p id="countdownText" class="countdown-text">Szkennelés... 3</p>
                </div>
            </div>

            <div id="successSection" style="display:none;">
                <div class="status-box bent success-big">
                    <div class="status-title" id="statusTitle">Sikeres belépés</div>
                    <div class="status-text" id="statusText">A rendszer szerint bent tartózkodsz a konditeremben.</div>
                </div>
            </div>

            <div id="kilepesQrSection" style="display:none;">
                <div class="status-box kint">
                    <div class="status-title">Kilépés folyamatban</div>
                    <div class="status-text">Mutasd fel a QR-kódot a kiléptető kapunál.</div>
                </div>

                <div class="qr-box">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=SmartGYM-Kilepes" alt="QR kód" />
                    <p class="qr-text">Kiléptető QR-kód</p>
                    <p id="kilepesCountdownText" class="countdown-text">Kilépés... 3</p>
                </div>
            </div>

            <form method="post" asp-page-handler="Kilep" class="kilepes-form" id="kilepesForm">
                <button type="button" class="main-btn kilep-btn" id="kilepesBtn" onclick="startKilepesQr()" style="display:none;">
                    Kilépés
                </button>
            </form>

            <script>
                        const qrSection = document.getElementById("qrSection");
                        const successSection = document.getElementById("successSection");
                        const kilepesQrSection = document.getElementById("kilepesQrSection");
                        const countdownText = document.getElementById("countdownText");
                        const kilepesCountdownText = document.getElementById("kilepesCountdownText");
                        const kilepesBtn = document.getElementById("kilepesBtn");
                        const kilepesForm = document.getElementById("kilepesForm");
                        const statusTitle = document.getElementById("statusTitle");
                        const statusText = document.getElementById("statusText");

                        const qrLejart = sessionStorage.getItem("qrLejart");

                        if (qrLejart === "igen") {
                            successSection.style.display = "block";
                            kilepesBtn.style.display = "inline-block";
                        } else {
                            qrSection.style.display = "block";

                            let mp = 3;
                            const timer = setInterval(() => {
                                mp--;

                                if (mp > 0) {
                                    countdownText.innerText = "Szkennelés... " + mp;
                                } else {
                                    clearInterval(timer);

                                    qrSection.style.display = "none";
                                    successSection.style.display = "block";
                                    kilepesBtn.style.display = "inline-block";

                                    sessionStorage.setItem("qrLejart", "igen");
                                }
                            }, 1000);
                        }

                        function startKilepesQr() {
                            successSection.style.display = "none";
                            kilepesBtn.style.display = "none";
                            kilepesQrSection.style.display = "block";

                            let mp = 3;
                            const timer = setInterval(() => {
                                mp--;

                                if (mp > 0) {
                                    kilepesCountdownText.innerText = "Kilépés... " + mp;
                                } else {
                                    clearInterval(timer);

                                    kilepesQrSection.style.display = "none";
                                    successSection.style.display = "block";

                                    statusTitle.innerText = "Sikeres kilépés";
                                    statusText.innerText = "A rendszer szerint sikeresen kiléptél.";

                                    sessionStorage.removeItem("qrLejart");

                                    setTimeout(() => {
                                        kilepesForm.submit();
                                    }, 1000);
                                }
                            }, 1000);
                        }
            </script>
        }
    </div>
</div>

<style>
    .belepes-wrapper {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 15px;
    }

    .belepes-card {
        width: 100%;
        max-width: 700px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        padding: 40px 30px;
        text-align: center;
        backdrop-filter: blur(18px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.35);
    }

        .belepes-card h2 {
            margin-bottom: 25px;
            font-size: 36px;
            font-weight: 700;
            color: white;
        }

    .alert-box {
        margin-bottom: 20px;
        padding: 14px 18px;
        border-radius: 14px;
        font-weight: 600;
    }

        .alert-box.success {
            background: rgba(34,197,94,0.15);
            color: #86efac;
            border: 1px solid rgba(34,197,94,0.35);
        }

        .alert-box.error {
            background: rgba(239,68,68,0.15);
            color: #fca5a5;
            border: 1px solid rgba(239,68,68,0.35);
        }

    .status-box {
        border-radius: 18px;
        padding: 28px 20px;
        margin-bottom: 24px;
        transition: 0.3s;
    }

        .status-box.bent {
            background: rgba(34,197,94,0.12);
            border: 1px solid rgba(34,197,94,0.35);
            box-shadow: 0 0 30px rgba(34,197,94,0.20);
        }

        .status-box.kint {
            background: rgba(239,68,68,0.10);
            border: 1px solid rgba(239,68,68,0.28);
            box-shadow: 0 0 30px rgba(239,68,68,0.15);
        }

    .status-title {
        font-size: 26px;
        font-weight: 700;
        margin-bottom: 10px;
        color: white;
    }

    .status-text {
        font-size: 16px;
        color: #cbd5e1;
    }

    .qr-box {
        margin: 0 auto 28px auto;
        max-width: 340px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 12px 35px rgba(0,0,0,0.25);
    }

        .qr-box img {
            width: 220px;
            height: 220px;
            background: white;
            padding: 12px;
            border-radius: 16px;
            margin-bottom: 14px;
        }

    .qr-text {
        color: white;
        font-size: 17px;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .countdown-text {
        color: #93c5fd;
        font-size: 15px;
        margin: 0;
    }

    .success-big {
        animation: fadeIn 0.35s ease;
    }

    .kilepes-form {
        margin-top: 10px;
    }

    .main-btn {
        min-width: 220px;
        border: none;
        border-radius: 14px;
        padding: 14px 28px;
        font-size: 20px;
        font-weight: 700;
        color: white;
        transition: 0.25s;
    }

        .main-btn:hover {
            transform: translateY(-2px) scale(1.02);
        }

    .belep-btn {
        background: linear-gradient(90deg, #16a34a, #22c55e);
        box-shadow: 0 0 22px rgba(34,197,94,0.45);
    }

    .kilep-btn {
        background: linear-gradient(90deg, #dc2626, #ef4444);
        box-shadow: 0 0 22px rgba(239,68,68,0.45);
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>